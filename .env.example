# ─────────────────────────────────────────────────────────────────────────
# Vendedor de IA · Unno Ambiental — variáveis de ambiente
# Copie para `.env.local` e preencha. NUNCA commite segredos (ver .gitignore).
# ─────────────────────────────────────────────────────────────────────────

# Domínio público de produção (para URLs absolutas de OG/Twitter). Opcional em
# dev; na Vercel, defina com seu domínio final (ex.: https://via.com.br).
NEXT_PUBLIC_SITE_URL="https://SEU-DOMINIO.com"

# Supabase — públicas (seguras no client; respeitam RLS)
NEXT_PUBLIC_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua-anon-key"

# Supabase — SERVER-ONLY (bypassa RLS; jamais no browser)
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"

# OpenAI — embeddings (text-embedding-3-small, 1536 dims). SERVER-ONLY.
OPENAI_API_KEY="sk-..."

# RAG — limiar de similaridade (0..1). Abaixo disso → "não sei" + escalonar.
RAG_SCORE_THRESHOLD="0.78"

# Mercos — REST (preço/estoque ao vivo). SERVER-ONLY.
MERCOS_API_URL="https://app.mercos.com/api/v1"
MERCOS_APPLICATION_TOKEN="seu-application-token"
MERCOS_COMPANY_TOKEN="seu-company-token"

# Omie — ERP/financeiro (leitura). SERVER-ONLY.
OMIE_APP_KEY="sua-app-key"
OMIE_APP_SECRET="seu-app-secret"

# WhatsApp Cloud API — token do handshake de verificação do webhook. SERVER-ONLY.
WHATSAPP_VERIFY_TOKEN="um-token-forte-que-voce-define"

# Twilio — voz + WhatsApp. SERVER-ONLY. (Console → Account Info)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="seu-auth-token"
TWILIO_VOICE_NUMBER="+5511999998888"       # número Twilio para ligações
TWILIO_WHATSAPP_NUMBER="+14155238886"      # número WhatsApp (sandbox ou BR)

# ElevenLabs — voz realista (TTS). SERVER-ONLY. (Settings → API Keys)
ELEVENLABS_API_KEY="sua-api-key"
ELEVENLABS_VOICE_ID="id-da-voz-escolhida"  # opcional (tem voz padrão)
ELEVENLABS_MODEL_ID="eleven_multilingual_v2"  # opcional
